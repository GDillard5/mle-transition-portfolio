# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp

# Data — usually huge or sensitive; track only schemas/samples explicitly.
data/*
!data/.gitkeep

# Notebooks (consider nbstripout to keep diffs clean)
.ipynb_checkpoints/

# OS
.DS_Store
